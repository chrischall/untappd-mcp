# Untappd login (your own account)
UNTAPPD_USERNAME=your_untappd_username
UNTAPPD_PASSWORD=your_untappd_password

# Untappd mobile app client credentials.
# Obtain by intercepting the Untappd mobile app's traffic (see README):
#   the POST https://api.untappd.com/v4/xauth request carries client_id &
#   client_secret in its query string.
UNTAPPD_CLIENT_ID=
UNTAPPD_CLIENT_SECRET=

# Optional overrides (sensible defaults are baked in):
# UNTAPPD_DEVICE_ID=A1B2C3D4-0000-4000-8000-0000000000AA
# UNTAPPD_UTV=4.0.0
# UNTAPPD_USER_AGENT=Untappd/4.7.13 (ios; iPadOS 26.5)
